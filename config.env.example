# =============================================================================
# CONFIGURAÇÃO DO PIPELINE AIO — copie para config.env e preencha
# =============================================================================

# --- Banco PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=seu_banco
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_SCHEMA=se_cgpac

# --- Gmail (preenchido automaticamente por gerar_token.py) ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# --- Opcional: quantos dias buscar por padrão ---
DIAS_RETROATIVOS=2
